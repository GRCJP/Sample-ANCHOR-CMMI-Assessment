# AWS Environment Variables Template

# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# AWS Resource Names
S3_BUCKET=cyberassess-demo
EVIDENCE_BUCKET=cyberassess-evidence
DYNAMODB_TABLE=cyberassess-data
COGNITO_USER_POOL=cyberassess-users
COGNITO_CLIENT_ID=your-cognito-client-id

# API Gateway
API_GATEWAY_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/prod

# Email Configuration (SES)
EMAIL_FROM=noreply@cyberassess.com
EMAIL_REGION=us-east-1

# Application Configuration
APP_NAME=CyberAssess Platform
APP_VERSION=2.4.1
APP_ENVIRONMENT=demo

# Security
JWT_SECRET=your-jwt-secret-key
SESSION_TIMEOUT=3600

# File Upload Limits
MAX_FILE_SIZE=2097152  # 2MB in bytes
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx

# Demo Configuration
DEMO_MODE=true
RESET_DATA_DAILY=true
